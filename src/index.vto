<h1>fermicalva</h1>
<p>しょうもない実験の供養場。</p>

<h2>Posts</h2>
<ul class="post-list">
{{ for post of search.pages("type=post", "date=desc") }}
<li>
  <span class="date">{{ post.date |> date("yyyy-MM-dd") }}</span><br>
  <a href="{{ post.url }}">{{ post.title }}</a>
</li>
{{ /for }}
</ul>
